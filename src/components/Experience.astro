---
import Section from "./Section.astro";

const experience = [
    {
        rol: "Desarrollo de páginas webs - Trabajo por demanda (Freelance)",
        año: "Jul 2021 - Actualidad",
        lugar: "ContenidosOnline",
        descripcion:
            "Desarrollo y mantenimiento de diversas páginas web, sobre todo institucionales, usando WordPress como CMS. Creación de plugins de WordPress personalizados para optimizar la gestión de contenido o mejorar la experiencia del usuario. En proyectos sin necesidad de CMS, utilización de HTML, CSS y JS.",
    },
    {
        rol: "Desarrollador frontend",
        año: "Ago 2022 - Feb 2025",
        detalle_contrato: "Full-time hasta Oct. 2023, luego flexible por horas",
        lugar: "Xirect Software Solutions",
        descripcion:
            "Creación y adaptación de interfaces de usuario personalizadas utilizando Vue (Nuxt) y React (Typescript). Colaboración en proyectos para entregar soluciones de alta calidad optimizadas para diferentes dispositivos. Uso de Cypress.io para testing.",
    },
    {
        rol: "Pasantía - Desarrolladora fullstack",
        año: "Oct. 2021 - Oct. 2022",
        lugar: "Municipalidad Gualeguaychú - Sector público / Gobierno local",
        descripcion:
            "Participación en el mantenimiento y creación de nuevas funciones para la aplicación 'GualeActiva' (PHP) y Javascript. Desarrollo de la primera versión del sitio web del área de turismo de la municipalidad utilizando WordPress.",
    },
    {
        rol: "Tecnicatura Superior en Análisis y Desarrollo de Software",
        año: "2019 - 2021",
        lugar: "Instituto Sedes Sapientiae",
        descripcion:
            "Formación académica técnica en análisis y desarrollo de sistemas.",
    },
];
---

<Section id="experiencia" classes="bg-gray-100">
    <div class="container px-5 py-24 mx-auto">
        <div class="flex flex-col text-center w-full mb-20">
            <h1
                class="title-font sm:text-4xl text-3xl mb-10 font-medium text-gray-900 text-center"
            >
                Experiencia
            </h1>
            <main class="grid lg:grid-col-2 md:grid-cols-2 grid-cols-1 gap-4">
                {
                    experience.map((exp) => (
                        <article class="bg-white h-full border-2 border-gray-200 border-opacity-60 rounded-lg overflow-hidden text-left p-5">
                            <div class="flex flex-col md:flex-row justify-between md:items-center gap-4">
                                <span class="text-sm font-mono text-gray-600 w-[60%]">
                                    {exp.lugar}
                                </span>
                                <time class="font-mono text-sm text-primary order-first md:order-2">
                                    {exp.año}
                                </time>
                            </div>
                            <h3 class="font-bold mb-3 text-lg">{exp.rol}</h3>
                            <p class="">{exp.descripcion}</p>
                        </article>
                    ))
                }
            </main>
        </div>
    </div>
</Section>
