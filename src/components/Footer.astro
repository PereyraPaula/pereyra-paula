---
import Logo from "./Logo.astro";
---

<footer class="text-gray-600 body-font border-t border-gray-200">
    <div
        class="container
    px-5
    py-12
    mx-auto
    flex
    md:items-center
    lg:items-start
    md:flex-row
    md:flex-nowrap
    flex-wrap
    flex-col
    gap-4"
    >
        <div class="md:w-1/3 w-full">
            <Logo />
        </div>
        <div class="md:w-1/3 w-full md:text-center">
            <h3 id="contacto" class="text-lg font-bold text-gray-900">
                Contacto
            </h3>
            <p>
                Si tienes un proyecto, pregunta o solo quieres conectar,
                escríbeme por correo o redes.
            </p>
            <div class="flex md:justify-center gap-4 mt-4">
                <a href="mailto:paulapereyrallorens@gmail.com">
                    <svg
                        class="text-inherit hover:cursor-pointer w-10 h-10 bg-gray-300 p-2 rounded-lg"
                        xmlns="http://www.w3.org/2000/svg"
                        width="32"
                        height="32"
                        viewBox="0 0 24 24"
                        ><path
                            fill="currentColor"
                            d="M22 6c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2zm-2 0l-8 4.99L4 6zm0 12H4V8l8 5l8-5z"
                        ></path></svg
                    >
                </a>
                <a
                    target="_blank"
                    href="https://www.linkedin.com/in/paula-pereyra-4b3127327"
                >
                    <svg
                        class="text-inherit hover:cursor-pointer w-10 h-10 bg-gray-300 p-2 rounded-lg"
                        xmlns="http://www.w3.org/2000/svg"
                        width="32"
                        height="32"
                        viewBox="0 0 64 64"
                        ><path
                            fill="currentColor"
                            d="M58.5 1H5.6C3.1 1 1.1 3 1.1 5.5v53c0 2.4 2 4.5 4.5 4.5h52.7c2.5 0 4.5-2 4.5-4.5V5.4C63 3 61 1 58.5 1M19.4 53.7h-9.1V24.2h9.1zm-4.6-33.6c-3 0-5.3-2.4-5.3-5.3s2.4-5.3 5.3-5.3s5.3 2.4 5.3 5.3s-2.2 5.3-5.3 5.3m39.1 33.6h-9.1V39.4c0-3.4-.1-7.9-4.8-7.9c-4.8 0-5.5 3.8-5.5 7.6v14.6h-9.1V24.2h8.9v4.1h.1c1.3-2.4 4.2-4.8 8.7-4.8c9.3 0 11 6 11 14.2v16z"
                        ></path></svg
                    >
                </a>
                <a target="_blank" href="https://github.com/PereyraPaula">
                    <svg
                        class="text-inherit hover:cursor-pointer w-10 h-10 bg-gray-300 p-2 rounded-lg"
                        xmlns="http://www.w3.org/2000/svg"
                        width="32"
                        height="32"
                        viewBox="0 0 24 24"
                        ><path
                            d="M5 3h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4.44c-.32-.07-.33-.68-.33-.89l.01-2.47c0-.84-.29-1.39-.61-1.67c2.01-.22 4.11-.97 4.11-4.44c0-.98-.35-1.79-.92-2.42c.09-.22.4-1.14-.09-2.38c0 0-.76-.23-2.48.93c-.72-.2-1.48-.3-2.25-.31c-.76.01-1.54.11-2.25.31c-1.72-1.16-2.48-.93-2.48-.93c-.49 1.24-.18 2.16-.09 2.38c-.57.63-.92 1.44-.92 2.42c0 3.47 2.1 4.22 4.1 4.47c-.26.2-.49.6-.57 1.18c-.52.23-1.82.63-2.62-.75c0 0-.48-.86-1.38-.93c0 0-.88 0-.06.55c0 0 .59.28 1 1.32c0 0 .52 1.75 3.03 1.21l.01 1.53c0 .21-.02.82-.34.89H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"
                            fill="currentColor"></path></svg
                    >
                </a>
            </div>
        </div>
        <div class="md:w-1/3 w-full md:text-right">
            <nav class="flex flex-col gap-y-1">
                <a
                    href="/"
                    class="mr-5 hover:text-gray-900 hover:cursor-pointer"
                    >Inicio</a
                >
                <a
                    href="/#trabajos"
                    class="mr-5 hover:text-gray-900 hover:cursor-pointer"
                    >Trabajos</a
                >
                <a
                    href="/#experiencia"
                    class="mr-5 hover:text-gray-900 hover:cursor-pointer"
                    >Experiencia</a
                >
                <a
                    href="/#sobre-mi"
                    class="mr-5 hover:text-gray-900 hover:cursor-pointer"
                    >Sobre mí</a
                >
            </nav>
        </div>
    </div>
</footer>
