---
import Logo from "./Logo.astro";
---

<div
    class="text-black body-font border-b border-gray-200 fixed w-full bg-white z-10 top-0"
>
    <div
        class="container mx-auto flex flex-wrap p-5 flex-col md:flex-row items-center gap-3"
    >
        <Logo text="PP" />
        <nav
            class="md:ml-auto md:mr-auto flex flex-wrap items-center text-base justify-center"
        >
            <a
                href="/"
                class="uppercase mr-5 hover:text-primary hover:cursor-pointer"
                >Inicio</a
            >
            <a
                href="#trabajos"
                class="uppercase mr-5 hover:text-primary hover:cursor-pointer"
                >Trabajos</a
            >
            <a
                href="#experiencia"
                class="uppercase mr-5 hover:text-primary hover:cursor-pointer"
                >Experiencia</a
            >
            <a
                href="#sobre-mi"
                class="uppercase mr-5 hover:text-primary hover:cursor-pointer"
                >Sobre mí</a
            >
        </nav>
        <a
            href="#contacto"
            class="uppercase inline-flex text-white bg-primary border-0 py-2 px-4 focus:outline-none hover:bg-primary/80 rounded text-md"
            >Contacto</a
        >
    </div>
</div>
