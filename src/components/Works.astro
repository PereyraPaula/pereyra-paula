---
import Section from "./Section.astro";

const trabajos = Object.values(
    import.meta.glob("../pages/posts/*.md", { eager: true }),
);
---

<Section id="trabajos">
    <div class="container py-24 px-10 mx-auto my-15">
        <h1
            class="title-font sm:text-4xl text-3xl mb-15 font-medium text-gray-900 text-center"
        >
            Trabajos
        </h1>
        <div
            class="grid lg:grid-col-4 md:grid-cols-3 grid-cols-1 gap-4 flex-row -m-4"
        >
            {
                trabajos.map((trabajo: any) => (
                    <div class="h-full border-2 border-gray-200 border-opacity-60 rounded-lg overflow-hidden">
                        <div class="lg:h-48 md:h-36 w-full overflow-hidden relative">
                            <div
                                class="w-full h-full bg-cover bg-top transition-[background-position] duration-[2s] ease-out delay-500
                               hover:bg-bottom hover:duration-[4s] hover:delay-0"
                                style={{
                                    backgroundImage: `url(${trabajo.frontmatter.imagen})`,
                                }}
                            />
                        </div>
                        <div class="p-6">
                            <h1 class="title-font text-lg font-medium text-gray-900 mb-3">
                                {trabajo.frontmatter.titulo}
                            </h1>
                            <p class="leading-relaxed mb-3">
                                {trabajo.frontmatter.descripcion}
                            </p>
                            <div class="flex justify-between items-center flex-wrap">
                                <a
                                    class="text-primary underline inline-flex items-center md:mb-2 lg:mb-0 mr-3"
                                    href={
                                        trabajo.frontmatter.enlace ??
                                        trabajo.frontmatter.repositorio
                                    }
                                >
                                    {trabajo.frontmatter.enlace
                                        ? "Ver sitio"
                                        : "Ver repositorio"}
                                </a>
                                <a
                                    href={trabajo.url}
                                    class="text-primary inline-flex items-center md:mb-2 lg:mb-0"
                                >
                                    Ver más
                                    <svg
                                        class="w-4 h-4 ml-2 my-0 py-0"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        fill="none"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    >
                                        <path d="M5 12h14" />
                                        <path d="M12 5l7 7-7 7" />
                                    </svg>
                                </a>
                            </div>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</Section>
