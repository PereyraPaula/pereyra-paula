---
import Footer from "../components/Footer.astro";
import Navbar from "../components/Navbar.astro";
import Section from "../components/Section.astro";
import Layout from "./Layout.astro";

const { frontmatter } = Astro.props;

const showImageInGrid = () => {
    return (
        frontmatter.imagen &&
        !frontmatter.imagen.includes("notshowinDetails=true")
    );
};
---

<Layout title={`Trabajo ${frontmatter.titulo} - Portfolio Paula Pereyra`}>
    <Navbar />
    <Section
        classes="mt-20 h-66 bg-linear-to-b from-sky-100 to-slate-50 text-black flex justify-start items-center "
    >
        <div class="container mx-auto px-10 text-6xl font-bold">
            {frontmatter.titulo}
        </div>
    </Section>
    <main
        class={`${showImageInGrid() ? "grid grid-cols-1 md:grid-cols-2" : "flex flex-col gap-4"} container mx-auto p-10 gap-10 md:relative min-h-screen`}
    >
        <div
            class={`text-black ${showImageInGrid() ? "prose" : ""} text-lg
            prose-h1:font-bold prose-h1:text-xl
            prose-a:text-black prose-img:rounded-xl
            prose-headings:underline prose-p:mb-2`}
        >
            <slot />
            <div
                class="border-4 border-blue-300 rounded-lg border-dotted w-full h-fit p-3 flex flex-col m-0 my-10"
            >
                <span><strong>Fecha: </strong>{frontmatter.fecha}</span>
                <span><strong>Industria: </strong>{frontmatter.industria}</span>
            </div>
        </div>
        {
            showImageInGrid() && (
                <img
                    src={frontmatter.imagen}
                    alt={frontmatter.titulo}
                    class="w-full max-w-192.5 rounded-lg"
                />
            )
        }
    </main>
    <Footer />
</Layout>
